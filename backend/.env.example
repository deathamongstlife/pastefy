# Pastely Configuration Example

# HTTP Server
HTTP_SERVER_PORT=8080
HTTP_SERVER_CORS=*

# Database Configuration
DATABASE_DRIVER=mysql
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=pastely
DATABASE_USER=root
DATABASE_PASSWORD=

# For SQLite instead:
# DATABASE_DRIVER=sqlite
# DATABASE_FILE=pastely.sqlite

# Server Configuration
SERVER_NAME=http://localhost:8080

# Pastely Features
PASTELY_LOGIN_REQUIRED=false
PASTELY_LOGIN_REQUIRED_CREATE=false
PASTELY_LOGIN_REQUIRED_READ=false
PASTELY_PUBLIC_PASTES=true
PASTELY_LIST_PASTES=true
PASTELY_PUBLIC_STATS=true
PASTELY_META_TAGS=true
PASTELY_AUTOMIGRATE=true
PASTELY_DEV=false

# OAuth2 Providers (optional)
OAUTH2_GITHUB_CLIENT_ID=
OAUTH2_GITHUB_CLIENT_SECRET=

OAUTH2_GOOGLE_CLIENT_ID=
OAUTH2_GOOGLE_CLIENT_SECRET=

OAUTH2_DISCORD_CLIENT_ID=
OAUTH2_DISCORD_CLIENT_SECRET=

# J.A.R.V.I.S AI Integration (optional)
JARVIS_GATEWAY_URL=http://127.0.0.1:18789
JARVIS_GATEWAY_TOKEN=your-token-here
JARVIS_AGENT_ID=main
JARVIS_TIMEOUT_MS=30000

# Elasticsearch (optional)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=changeme
# Or use API key instead:
# ELASTICSEARCH_API_KEY=your-api-key

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO/S3 Storage (optional)
MINIO_SERVER=http://localhost:9000
MINIO_BUCKET=pastely
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION=us-east-1

# Rate Limiting (optional)
RATELIMITER_MILLIS=5000
RATELIMITER_LIMIT=5
