http.server.port=1337
HTTP_SERVER_CORS=*

DATABASE_DRIVER=mysql
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_HOST=
DATABASE_PORT=3306

SERVER_NAME=

OAUTH2_INTERAAPPS_CLIENT_ID=NONE
OAUTH2_INTERAAPPS_CLIENT_SECRET=

OAUTH2_GITHUB_CLIENT_ID=NONE
OAUTH2_GITHUB_CLIENT_SECRET=

OAUTH2_GOOGLE_CLIENT_ID=NONE
OAUTH2_GOOGLE_CLIENT_SECRET=

OAUTH2_DISCORD_CLIENT_ID=NONE
OAUTH2_DISCORD_CLIENT_SECRET=

OAUTH2_TWITCH_CLIENT_ID=NONE
OAUTH2_TWITCH_CLIENT_SECRET=

# Pastely Configuration (NEW in 7.0)
# Note: Old PASTELY_* variables are deprecated but still supported for backward compatibility
PASTELY_LOGIN_REQUIRED=false
PASTELY_LOGIN_REQUIRED_CREATE=false
PASTELY_LOGIN_REQUIRED_READ=false
PASTELY_LIST_PASTES=true
PASTELY_PUBLIC_STATS=true
PASTELY_PUBLIC_PASTES=true
PASTELY_META_TAGS=true
PASTELY_CUSTOM_BODY=
PASTELY_CUSTOM_HEADER=
PASTELY_PAGINATION_PAGE_LIMIT=20
PASTELY_DEV=false
PASTELY_AUTOMIGRATE=true
PASTELY_GRANT_ACCESS_REQUIRED=false

# Elasticsearch (optional)
ELASTICSEARCH_URL=
ELASTICSEARCH_USER=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_API_KEY=

# Redis (optional - for caching)
REDIS_HOST=
REDIS_PORT=6379
REDIS_POOL_MAX=128
REDIS_POOL_MAX_IDLE=64
REDIS_POOL_MIN_IDLE=16

# MinIO/S3 (optional - for file storage)
MINIO_SERVER=
MINIO_BUCKET=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# AI Features (optional - Anthropic Claude)
AI_ANTHROPIC_TOKEN=

# Email Configuration (optional - for verification/password reset)
# SMTP settings for sending authentication emails
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=noreply@pastely.app
EMAIL_FROM_NAME=Pastely